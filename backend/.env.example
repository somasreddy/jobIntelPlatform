# Environment Variables Example (Backend)

# Database - Neon.tech recommended
# Format: postgresql+asyncpg://user:pass@ep-xxx.neon.tech/neondb?ssl=require
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/job_platform

# Redis - Upstash.com recommended
# Format: rediss://default:password@name.upstash.io:6379
REDIS_URL=redis://localhost:6379/0

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-xxx

# Anthropic Model (Default: claude-haiku-4-5-20251001)
# Use claude-sonnet-4-6 for higher quality
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# CORS Origins (Comma separated or JSON array)
# Example: https://your-app.vercel.app,http://localhost:3000
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]

# ── Job Discovery API Keys ────────────────────────────────────────────────────
# Adzuna — free tier, register at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# JSearch (RapidAPI) — aggregates LinkedIn, Indeed, Glassdoor, Naukri
# Free tier: 200 req/month  https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=
