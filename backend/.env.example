# --- Database (Neon.tech Recommended for Vercel) ---
DATABASE_URL=postgresql+asyncpg://user:pass@ep-hostname.region.aws.neon.tech/neondb

# --- Redis (Upstash Recommended for Vercel Serverless) ---
# Example: rediss://default:your-password@your-endpoint.upstash.io:6379
REDIS_URL=redis://localhost:6379/0

# --- LLM API Keys ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
PERPLEXITY_API_KEY=

# New Alternative Providers
MISTRAL_API_KEY=
COHERE_API_KEY=
TOGETHER_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=

# --- Default Models ---
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OPENAI_MODEL=gpt-4o
GOOGLE_MODEL=gemini-2.0-flash
GROQ_MODEL=llama-3.3-70b-versatile
MISTRAL_MODEL=mistral-small-latest
COHERE_MODEL=command-r
TOGETHER_MODEL=meta-llama/Llama-3-70b-chat-hf
DEEPSEEK_MODEL=deepseek-chat
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free
HUGGINGFACE_MODEL=Qwen/Qwen2.5-72B-Instruct

# --- Fallback Strategy ---
LLM_FALLBACK_ORDER=groq,deepseek,mistral,openrouter,openai,anthropic,google

# --- Feature Flags ---
CONSOLIDATED_MODE=true

# --- Job Discovery API Keys ---
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JSEARCH_API_KEY=

# --- CORS Origins (Add your Vercel frontend URL here) ---
CORS_ORIGINS=["http://localhost:3000", "https://your-app.vercel.app"]
